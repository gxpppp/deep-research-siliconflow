# ==========================================
# DeepResearch Platform - 环境变量配置
# ==========================================

# ------------------------------------------
# SiliconFlow API 配置 (必填)
# ------------------------------------------
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEFAULT_MODEL=deepseek-ai/DeepSeek-V2.5

# ------------------------------------------
# 外部工具 API 配置 (必填)
# ------------------------------------------
# SerpAPI 密钥 (Google 搜索) - https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Jina AI API 密钥 (网页提取) - https://jina.ai/reader
# 可选：免费版有额度限制，不填则使用基础功能
JINA_API_KEY=your_jina_api_key_here

# ------------------------------------------
# 后端服务配置
# ------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# CORS 配置 (开发环境使用，生产环境请限制域名)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------
# 缓存配置 (MVP 使用内存缓存，可选 Redis)
# ------------------------------------------
# 设置为 "redis" 启用 Redis 缓存，否则使用内存缓存
CACHE_TYPE=memory
CACHE_TTL=3600

# Redis 配置 (仅当 CACHE_TYPE=redis 时需要)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ------------------------------------------
# 日志配置
# ------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ------------------------------------------
# 安全与限流
# ------------------------------------------
# 请求超时设置 (秒)
TOOL_TIMEOUT=15
TOTAL_TIMEOUT=120
MAX_RESEARCH_LENGTH=50000

# 速率限制 (每分钟请求数)
RATE_LIMIT_PER_MINUTE=30
