# ==========================================
# DeepResearch Platform - 环境变量配置
# ==========================================

# ------------------------------------------
# SiliconFlow API 配置 (必填)
# ------------------------------------------
# 请从 https://cloud.siliconflow.cn/ 获取 API Key
SILICONFLOW_API_KEY=sk-test-placeholder
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEFAULT_MODEL=deepseek-ai/DeepSeek-V2.5

# ------------------------------------------
# 外部工具 API 配置 (必填)
# ------------------------------------------
# 请从 https://serpapi.com/ 获取 API Key
SERPAPI_KEY=test-placeholder

# Jina AI API 密钥 (网页提取) - 可选
JINA_API_KEY=

# ------------------------------------------
# 后端服务配置
# ------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------
# 缓存配置
# ------------------------------------------
CACHE_TYPE=memory
CACHE_TTL=3600

# ------------------------------------------
# 日志配置
# ------------------------------------------
LOG_LEVEL=INFO
